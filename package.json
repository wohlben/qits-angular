{
  "name": "@qits/angular",
  "version": "0.0.1",
  "private": true,
  "description": "qits integration for Angular apps: config.json-gated OTEL telemetry (traces, logs, route/interaction/caller enrichment), later feature capture and state snapshots.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wohlben/qits-angular.git"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build qits-angular",
    "test": "ng test qits-angular",
    "test:browser": "ng run qits-angular:test-browser",
    "lint": "ng lint qits-angular",
    "check-exports": "node scripts/check-exports.mjs",
    "prepare": "ng build qits-angular && node scripts/check-exports.mjs"
  },
  "files": [
    "dist/qits-angular"
  ],
  "exports": {
    ".": {
      "types": "./dist/qits-angular/types/qits-angular.d.ts",
      "default": "./dist/qits-angular/fesm2022/qits-angular.mjs"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "@angular/core": "^21.2.0",
    "@angular/router": "^21.2.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/instrumentation-document-load": "^0.65.0",
    "@opentelemetry/instrumentation-fetch": "^0.220.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.64.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-trace-web": "^2.9.0",
    "tslib": "^2.3.0"
  },
  "pnpm": {
    "packageExtensions": {
      "@opentelemetry/instrumentation-user-interaction": {
        "peerDependenciesMeta": {
          "zone.js": {
            "optional": true
          }
        }
      }
    }
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.4.0",
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.1",
    "rxjs": "~7.8.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.1.9"
  }
}
